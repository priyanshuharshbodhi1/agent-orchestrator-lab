# Exclude unnecessary directories and files from ESLint

# Dependencies
node_modules/
**/node_modules/

# Build outputs
dist/
packages/*/dist/
packages/*/dist-server/

# Test files
coverage/
*.coverage.js
packages/*/coverage/

# Configuration files
eslint.config.js
.prettierrc
.prettierignore
tsconfig.json

# Web/Next.js specific (build artifacts)
packages/web/.next/
packages/web/next-env.d.ts

# Documentation
docs/
*.md

# Misc
.DS_Store
*.swp
.cache
